# Backend Environment Variables
# Copy this file to .env and update with your values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=0.0.0.0.0,127.0.0.1

# Database (default SQLite, can be changed to PostgreSQL/MySQL)
DATABASE_URL=sqlite:///db.sqlite3

# CORS Settings - Frontend URL
FRONTEND_URL=http://0.0.0.0.0
CORS_ALLOWED_ORIGINS=http://0.0.0.0.0,http://0.0.0.0.0:80,http://0.0.0.0.0:3000

# Optional: Email settings, etc.
